# Hivebrite Configuration
# Copy to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────

# Your Hivebrite community URL
HIVEBRITE_BASE_URL=https://yourcommunity.hivebrite.com

# OAuth2 access token (for bearer token mode)
HIVEBRITE_ACCESS_TOKEN=

# ─── OAuth2 Password Grant (alternative to bearer token) ─────────────────────

# HIVEBRITE_CLIENT_ID=
# HIVEBRITE_CLIENT_SECRET=
# HIVEBRITE_ADMIN_EMAIL=
# HIVEBRITE_ADMIN_PASSWORD=

# ─── OAuth2 Refresh Token (alternative to password grant) ────────────────────

# HIVEBRITE_CLIENT_ID=
# HIVEBRITE_CLIENT_SECRET=
# HIVEBRITE_REFRESH_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# Max results per page (default: 25, max: 100)
# HIVEBRITE_MAX_RESULTS=25
